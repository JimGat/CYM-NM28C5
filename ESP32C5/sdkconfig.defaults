# NM-CYD-C5 project defaults
# These override the chip defaults and are preserved across set-target/fullclean

# Main task stack — must be large enough for LVGL UI construction + large local buffers
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Bluetooth / NimBLE
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_EXT_ADV=y
# Allow NimBLE host buffers (MSYS/ACL/HCI) to use PSRAM via default allocator
# instead of forcing all NimBLE allocations into internal DRAM. The BLE radio
# controller's DMA buffers are allocated with MALLOC_CAP_DMA regardless of this
# setting and always land in internal SRAM.
CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_EXTERNAL=y

# PSRAM (8 MB SPIRAM on NM-CYD-C5)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_USE_MALLOC=y
# Increase internal DMA reserve pool from 32 KB → 40 KB. WiFi static RX (6×1700)
# + TX (4×~1700) + BLE LL controller all share this pool. Extra 8 KB gives BLE
# enough headroom to initialize alongside a retained (not deinit'd) WiFi driver.
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=49152
# Reduce WiFi static RX 10→4 and TX 4→3 to free DMA pool for BLE controller.
# Both BLE LL env and HCI UART transport allocate from the DMA pool regardless
# of NIMBLE_MEM_ALLOC_MODE. WiFi + BLE together need ~42 KB of DMA-capable
# SRAM; 48 KB pool gives ~6 KB margin. RX≥3 and TX≥2 are ESP-IDF minimums.
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_STATIC_TX_BUFFER_NUM=3

# LVGL fonts used by the UI
CONFIG_LV_FONT_MONTSERRAT_12=y
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_28=y

# Flash size (NM-CYD-C5 has 16 MB flash)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Panic handler in IRAM — must be set so the panic/backtrace handler can execute
# even when the flash cache is temporarily disabled (e.g. during NVS/flash writes).
# Without this, any fault that fires during a cache-dark window causes CPU_LOCKUP
# because the panic handler can't fetch its own code from flash.
CONFIG_ESP_PANIC_HANDLER_IRAM=y

# Task WDT panic — converts silent watchdog reboot into a full panic with register
# dump and backtrace so we can see which task/line caused the hang.
CONFIG_ESP_TASK_WDT_PANIC=y

# mbedTLS memory — use system allocator so PSRAM (via SPIRAM_USE_MALLOC) is
# available for TLS context structures instead of a fixed internal-RAM pool.
# DYNAMIC_BUFFER defers the 16 KB SSL I/O buffer allocation until a connection
# is actually in progress and frees it immediately after, preventing the internal
# heap from being exhausted before the TLS handshake can start.
CONFIG_MBEDTLS_DEFAULT_MEM_ALLOC=y
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y

# Smaller CA bundle — "common" set covers every major commercial CA
# (Amazon, DigiCert, Let's Encrypt, Comodo, GeoTrust, etc.) used by
# WiGLE and WDGWars, while consuming ~60 % less flash/parse overhead
# than the full Mozilla bundle.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y
